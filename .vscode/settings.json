{
  "java.jdt.ls.vmargs": "-XX:+UseParallelGC -XX:GCTimeRatio=4 -XX:AdaptiveSizePolicyWeight=90 -Dsun.zip.disableMemoryMapping=true -Xmx16G -Xms2G -Xlog:disable",
  "java.import.gradle.annotationProcessing.enabled": true,
  "java.import.gradle.enabled": true,
  "[java]": {
    "editor.defaultFormatter": "RudraPatel.prettier-plugin-java-vscode"
  },
  "java.compile.nullAnalysis.mode": "disabled",
  "formatAll.includeFileExtensions": [".java", ".json"],
  "formatAll.excludeFolders": [
    "bin",
    "build",
    "run-data",
    "run"
  ],
  "java.configuration.updateBuildConfiguration": "interactive"
}
